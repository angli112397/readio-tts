READIO_PROVIDER=gpt
READIO_GATEWAY_BIND=0.0.0.0
READIO_GATEWAY_PORT=8090
READIO_DATA_DIR=C:/Users/your-name/AppData/Local/ReadioTTS
READIO_MAX_CHAPTER_CHARACTERS=500000
READIO_JOB_RETENTION_DAYS=7
READIO_GPT_BASE_URL=http://127.0.0.1:9880
READIO_GPT_MODEL_REVISION=v2ProPlus
READIO_GPT_TIMEOUT_SECONDS=300
READIO_GPT_REFERENCE_DIR=references/gpt
READIO_GPT_JOB_DATA_REMOTE_DIR=job-data/jobs
READIO_GPT_TEXT_LANG=zh
READIO_GPT_PROMPT_LANG=zh
READIO_GPT_TEXT_SPLIT_METHOD=cut0
READIO_GPT_BATCH_SIZE=1
READIO_GPT_TOP_K=15
READIO_GPT_TOP_P=1.0
READIO_GPT_TEMPERATURE=1.0
READIO_GPT_SPEED_FACTOR=1.0
READIO_GPT_FRAGMENT_INTERVAL=0.3
READIO_GPT_SEED=-1
